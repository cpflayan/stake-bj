# =============================================
# Stake Blackjack Bot - 環境變數設定
# =============================================
# 複製此檔案為 .env 並填入您的設定

# --- 認證 ---
# 從瀏覽器 Cookie 取得 (登入 stake.com 後按 F12 > Application > Cookies)
STAKE_TOKEN=your_stake_access_token_here

# --- 投注設定 ---
BET_AMOUNT=0.00000001         # 初始投注金額 (USD)
MAX_BET=0.0001                # 最大投注金額 (USD)
MIN_BET=0.00000001            # 最小投注金額 (USD)
STOP_PROFIT=0.001             # 達到此金額時停止 (USD)
STOP_LOSS=0.001               # 虧損此金額時停止 (USD)

# --- 策略設定 ---
STRATEGY=basic                # basic | martingale | flat (目前實作: basic + martingale)
MARTINGALE_MULTIPLIER=2.0     # Martingale 倍數 (策略為 martingale 時生效)
MAX_MARTINGALE_STEPS=5        # 最大 Martingale 步數

# --- 速度控制 ---
BET_DELAY=1.0                 # 每局之間的延遲 (秒)
MAX_ROUNDS=100                # 最大局數 (0 = 無限)

# --- 日誌設定 ---
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/blackjack.log   # 日誌檔案路徑

# --- 貨幣設定 ---
CURRENCY=usd                  # 幣種 (usd / btc / eth etc.)
